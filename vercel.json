{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/results", "dest": "/api/results.js" },
    { "src": "/api/submit", "dest": "/api/submit.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
